{
  "name": "sftp-client",
  "version": "1.0.8",
  "description": "Mavi SFTP Client",
  "author": "Mavi",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.renderer.json && npm run copy-python",
    "copy-python": "powershell -NoProfile -Command \"New-Item -ItemType Directory -Force 'dist\\main\\python' | Out-Null; Copy-Item -Force 'src\\main\\python\\*.py' 'dist\\main\\python\\'\"",
    "start": "npm run build && electron .",
    "dev": "npm run build && concurrently \"tsc -p tsconfig.json --watch\" \"tsc -p tsconfig.renderer.json --watch\" \"electron .\"",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "prepare-runtime": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-python-runtime.ps1",
    "installer": "npm run prepare-runtime && npm run dist",
    "release": "npm run prepare-runtime && npm run build && electron-builder --publish never"
  },
  "build": {
    "appId": "com.mavi.sftp-client",
    "productName": "Mavi SFTP",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/icon.ico",
      "build/icon-taskbar.png",
      "src/renderer/html/**/*",
      "src/renderer/css/**/*",
      "src/renderer/assets/**/*",
      "src/renderer/fonts/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "dist/main/python/**/*"
    ],
    "extraResources": [
      {
        "from": "build/python-runtime",
        "to": "python",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "Manual-do-Usuario-Mavi-SFTP.docx",
        "to": "manual/Manual-do-Usuario-Mavi-SFTP.docx"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mavi SFTP",
      "artifactName": "Mavi-SFTP-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "LeonardoMavi",
      "repo": "mavi-sftp",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^26.15.3",
    "electron-reload": "^2.0.0-alpha.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@types/ssh2-sftp-client": "^9.0.3",
    "electron-updater": "^6.8.9",
    "ssh2-sftp-client": "^10.0.3"
  }
}
